.DS_Store
__pycache__/
*.pyc
.venv/
.ipynb_checkpoints/

# Internal Drive CONTENT cache (full-text extracts + substantive summaries) —
# classified `internal` per docs/PRIVACY.md. MUST NOT be committed to this PUBLIC repo;
# durable internal copy is on blob / a private repo. NOTE: the Drive *manifest*
# (metadata only) is PUBLIC and lives at infrastructure/drive-index.md, not here.
drive/

# MkDocs build output (published by the Pages workflow, not committed)
/site/

# Downloaded framework-PDF cache (regeneratable by scripts/gen_framework_*.py via the
# browser fetcher) — the extracted text + captions ARE committed under raw/frameworks/,
# but the source PDFs are not. Keeps the public repo from carrying binary blobs.
raw/.pdf-cache/
